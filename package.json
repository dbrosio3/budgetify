{
  "name": "budgetify-bot",
  "version": "1.0.0",
  "description": "Telegram bot for financial transaction processing using AI",
  "main": "src/server.ts",
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun --watch src/server.ts",
    "test": "bun test",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "deploy": "bash scripts/deploy.sh deploy -a budgetify-bot",
    "deploy:logs": "bash scripts/deploy-logs.sh",
    "deploy:status": "bash scripts/deploy-status.sh"
  },
  "keywords": [
    "telegram",
    "bot",
    "budget",
    "finance",
    "ai",
    "gemini"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "express": "^4.18.2",
    "googleapis": "^128.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.7.4",
    "typescript": "^5.3.2"
  }
}
